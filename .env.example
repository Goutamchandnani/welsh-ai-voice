# Llais Cymraeg — Environment Configuration
# Copy this file to .env and fill in your real values
# NEVER commit .env to Git — it's already in .gitignore

# Phase 1: Mozilla Data Collective (MDC)
MDC_API_KEY=your_key_here
MDC_DATASET_ID=cmn2g9w1h01m6mm07lq2w14dd

# Phase 2: Hugging Face (HF)
HF_TOKEN=your_huggingface_token_here

# Phase A: Supabase (Authentication & Logging)
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here
HF_ORG=llais-cymraeg

# --- Redis (Upstash free tier) ---
REDIS_URL=your_upstash_redis_url_here

# --- API Settings ---
API_HOST=0.0.0.0
API_PORT=8000
LOG_LEVEL=info

# --- Welsh Language Settings ---
WELSH_ISO_CODE=cy
DEFAULT_DIALECT=south   # options: north, south
